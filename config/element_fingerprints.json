    "mercari": {
        "shops": {
            "title": {
                "validators": {
                    "min_length": 3,
                    "max_length": 500,
                    "must_not_contain": ["<!DOCTYPE", "<html", "<script"]
                },
                "fingerprint": {
                    "tag_names": ["h1", "h2", "span"],
                    "text_pattern": ".{3,200}",
                    "hint_attributes": {"data-testid": "product-name"}
                }
            },
            "price": {
                "validators": {
                    "must_match": "[¥￥\\d,円]+",
                    "numeric_range": [1, 99999999]
                },
                "fingerprint": {
                    "tag_names": ["span", "p", "div"],
                    "text_pattern": "[¥￥]\\s*[\\d,]+|[\\d,]+\\s*円",
                    "hint_attributes": {"data-testid": "product-price"}
                }
            },
            "description": {
                "validators": {
                    "min_length": 10
                },
                "fingerprint": {
                    "tag_names": ["div", "p", "section"],
                    "text_pattern": ".{10,}",
                    "hint_attributes": {"data-testid": "product-description"}
                }
            },
            "images": {
                "validators": {
                    "url_pattern": "^https?://"
                },
                "fingerprint": {
                    "tag_names": ["img"],
                    "src_pattern": "static\\.mercdn\\.net|mercari",
                    "hint_attributes": {}
                }
            }
        },
