# Core runtime
APP_ENV=development
RUNTIME_ROLE=
DATABASE_URL=sqlite:///mercari.db
SECRET_KEY=change-this-to-a-random-32-byte-minimum-secret

# Production security
# In production or when RUNTIME_ROLE is web/worker, SECRET_KEY and REDIS_URL/VALKEY_URL are required.
# Leave blank to use environment-aware defaults: production enables HTTPS/HSTS/secure cookies,
# development keeps them relaxed for localhost.
REDIS_URL=
VALKEY_URL=
FORCE_HTTPS=
HSTS_ENABLED=
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false
SESSION_COOKIE_SECURE=
SESSION_COOKIE_SAMESITE=Lax

# Registration and authentication throttling
# Leave blank to allow local development signup and disable production signup by default.
ALLOW_PUBLIC_SIGNUP=
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW_SECONDS=900
REGISTER_RATE_LIMIT=3
REGISTER_RATE_WINDOW_SECONDS=3600

# Upload and external image limits
MAX_CONTENT_LENGTH=8388608
MAX_IMAGE_DOWNLOAD_BYTES=5242880
MAX_IMAGE_PIXELS=20000000
# Optional comma-separated host allowlist for external image fetches.
ALLOWED_IMAGE_HOSTS=

# Local image cache
IMAGE_STORAGE_PATH=static/images
PORT=5000
